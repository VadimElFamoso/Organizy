# Environment: dev or prod (prod enforces all secrets)
ENVIRONMENT=dev

# Database password (used by docker-compose)
POSTGRES_PASSWORD=launchpad

# Google OAuth (get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT Secret (min 32 chars - generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your-super-secret-key-at-least-32-characters

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_ID_PRO_MONTHLY=price_your-monthly-price-id
STRIPE_PRICE_ID_PRO_YEARLY=price_your-yearly-price-id

# URLs (for VPS deployment)
# DOMAIN=launchpad.example.com
# FRONTEND_URL=https://launchpad.example.com
# GOOGLE_REDIRECT_URI=https://launchpad.example.com/api/v1/auth/google/callback
