# Environment: dev or prod (prod enforces all secrets)
ENVIRONMENT=dev

# Database
DATABASE_URL=postgresql+asyncpg://launchpad:launchpad@localhost:5432/launchpad

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# JWT (min 32 chars - generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your-super-secret-key-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_ID_PRO_MONTHLY=price_your-monthly-price-id
STRIPE_PRICE_ID_PRO_YEARLY=price_your-yearly-price-id

# Frontend
FRONTEND_URL=http://localhost:5173
